# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key are safe for client-side use.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key is ONLY used server-side (API routes).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Publishable key is used client-side (checkout redirect).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key is ONLY used server-side. Never expose.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Create these in Stripe Dashboard → Products → Prices, then paste IDs here.
STRIPE_PRICE_MONTHLY=price_...          # $10/month recurring
STRIPE_PRICE_LIFETIME_EARLY=price_...   # $50 one-time early adopter
STRIPE_PRICE_LIFETIME_STANDARD=price_... # $100 one-time standard

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this deployed Next.js app (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of admin user emails.
ADMIN_EMAILS=you@example.com
