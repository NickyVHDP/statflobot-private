# Supabase — public keys (safe to include in build)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# URL of the deployed cloud dashboard (no trailing slash)
VITE_CLOUD_API_URL=https://your-autocloser-dashboard.vercel.app

# Comma-separated admin emails for showing the Admin tab
VITE_ADMIN_EMAILS=you@example.com
