# Copied into ui/client/.env before building.
# These are VITE build-time injections — safe public keys only.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# URL of your deployed Next.js cloud dashboard (no trailing slash).
# Used for billing portal + checkout redirect from inside the app.
VITE_CLOUD_API_URL=https://your-autocloser-dashboard.vercel.app

# Comma-separated admin emails — controls admin tab visibility.
VITE_ADMIN_EMAILS=you@example.com
