# Statflo Ruflo Bot — Environment Config
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Base URL for the Statflo instance
STATFLO_BASE_URL=https://csok.app.us.statflo.com

# Path to the accounts page
STATFLO_ACCOUNTS_PATH=/accounts

# Where to store the persistent browser session (relative to project root)
SESSION_PROFILE_DIR=./playwright-profile

# Global error threshold — stop the run after this many consecutive failures
MAX_CONSECUTIVE_ERRORS=3

# Set to "true" to show the browser window while running (easier to debug)
HEADLESS=false

# ─── License / Monetization (optional — only needed after deploying the dashboard) ──
# URL of your deployed Ruflo dashboard (no trailing slash).
LICENSE_API_URL=https://your-ruflo-dashboard.vercel.app

# Your personal license key — found in the dashboard under "License Key".
RUFLO_LICENSE_KEY=RUFLO-XXXX-XXXX-XXXX-XXXX

# Set to "true" to skip license verification during local development.
# NEVER set this to true in production.
# LICENSE_SKIP=true
